{
  "name": "project-management-system",
  "version": "1.0.0",
  "description": "Project & Task Management System with Layered Architecture",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker": "node src/workers/overdueWorker.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:verbose": "jest --forceExit --detectOpenHandles --verbose",
    "test:coverage": "jest --forceExit --detectOpenHandles --coverage",
    "test:integration": "jest --config jest.integration.config.js --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/integration/"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/**"
    ]
  },
  "keywords": [
    "project-management",
    "task-management",
    "express",
    "mysql",
    "redis",
    "rabbitmq"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "amqplib": "^0.10.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.0",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "redis": "^4.6.7",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
